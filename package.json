{
    "name": "agency-os",
    "version": "1.0.0",
    "private": true,
    "description": "AgencyOS - Modular Monolith Monorepo SaaS Platform",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "clean": "turbo clean",
        "test:api": "newman run postman/trifusion-dynamics.postman_collection.json -e postman/local.postman_environment.json --reporters cli,json --reporter-json-export postman/results.json"
    },
    "devDependencies": {
        "autocannon": "^8.0.0",
        "axios": "^1.18.1",
        "newman": "^6.2.2",
        "socket.io-client": "^4.8.3",
        "turbo": "^2.0.4",
        "typescript": "^5.4.5"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "bcrypt",
            "prisma"
        ]
    },
    "packageManager": "pnpm@10.26.1"
}
